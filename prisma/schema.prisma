generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum LinkStatus {
  ACTIVE
  PAUSED
  BLOCKED
  EXPIRED
}

enum DomainStatus {
  PENDING
  VERIFYING
  ACTIVE
  FAILED
}

enum ApiKeyScope {
  READ
  WRITE
  ANALYTICS
  ADMIN
}

model User {
  id          String       @id @db.Uuid
  email       String       @unique
  name        String?
  avatarUrl   String?      @map("avatar_url")
  isAdmin     Boolean      @default(false) @map("is_admin")
  isSuspended Boolean      @default(false) @map("is_suspended")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships Membership[]
  createdLinks Link[]      @relation("CreatedLinks")
  apiKeys     ApiKey[]
  auditEvents AuditEvent[] @relation("ActorAuditEvents")

  @@map("users")
}

model Workspace {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships Membership[]
  links       Link[]
  domains     Domain[]
  apiKeys     ApiKey[]
  invitations WorkspaceInvitation[]

  @@map("workspaces")
}

model WorkspaceInvitation {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid @map("workspace_id")
  email       String
  role        WorkspaceRole @default(EDITOR)
  tokenHash   String        @unique @map("token_hash")
  expiresAt   DateTime      @map("expires_at")
  acceptedAt  DateTime?     @map("accepted_at")
  createdById String        @db.Uuid @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, email])
  @@map("workspace_invitations")
}

model Membership {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid @map("user_id")
  workspaceId String        @db.Uuid @map("workspace_id")
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
  @@map("memberships")
}

model Domain {
  id             String       @id @default(uuid()) @db.Uuid
  workspaceId    String       @db.Uuid @map("workspace_id")
  hostname       String       @unique
  status         DomainStatus @default(PENDING)
  verificationId String?      @map("verification_id")
  isPrimary      Boolean      @default(false) @map("is_primary")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links          Link[]

  @@index([workspaceId, status])
  @@map("domains")
}

model Link {
  id                  String     @id @default(uuid()) @db.Uuid
  workspaceId         String     @db.Uuid @map("workspace_id")
  createdById         String     @db.Uuid @map("created_by_id")
  domainId            String?    @db.Uuid @map("domain_id")
  slug                String     @unique
  title               String?
  destination         String
  status              LinkStatus @default(ACTIVE)
  passwordHash        String?    @map("password_hash")
  expiresAt           DateTime?  @map("expires_at")
  maxClicks           Int?       @map("max_clicks")
  clickCount          Int        @default(0) @map("click_count")
  uniqueClickCount    Int        @default(0) @map("unique_click_count")
  trafficSharePercent Int?       @map("traffic_share_percent")
  targeting           Json?
  utm                 Json?
  tags                String[]
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  workspace           Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy           User       @relation("CreatedLinks", fields: [createdById], references: [id], onDelete: Restrict)
  domain              Domain?    @relation(fields: [domainId], references: [id], onDelete: SetNull)
  clicks              Click[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status, expiresAt])
  @@map("links")
}

model Click {
  id          String   @id @default(uuid()) @db.Uuid
  linkId      String   @db.Uuid @map("link_id")
  occurredAt  DateTime @default(now()) @map("occurred_at")
  ipHash      String?  @map("ip_hash")
  country     String?
  city        String?
  browser     String?
  os          String?
  device      String?
  referrer    String?
  userAgent   String?  @map("user_agent")
  destination String
  isPromo     Boolean  @default(false) @map("is_promo")
  isBot       Boolean  @default(false) @map("is_bot")
  link        Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, occurredAt(sort: Desc)])
  @@index([occurredAt(sort: Desc)])
  @@index([country])
  @@map("clicks")
}

model ApiKey {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid @map("user_id")
  workspaceId String        @db.Uuid @map("workspace_id")
  name        String
  prefix      String
  keyHash     String        @unique @map("key_hash")
  scopes      ApiKeyScope[]
  lastUsedAt  DateTime?     @map("last_used_at")
  expiresAt   DateTime?     @map("expires_at")
  revokedAt   DateTime?     @map("revoked_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, revokedAt])
  @@map("api_keys")
}

model PromoUrl {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  destination String
  weight      Int      @default(100)
  active      Boolean  @default(true)
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  countryAllowlist String[] @map("country_allowlist")
  clickCount  Int      @default(0) @map("click_count")
  revenueCents Int     @default(0) @map("revenue_cents")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([active, startsAt, endsAt])
  @@map("promo_urls")
}

model GlobalSettings {
  id                    String   @id @default("global")
  promoRedirectPercent  Int      @default(20) @map("promo_redirect_percent")
  anonymousLinksEnabled Boolean  @default(true) @map("anonymous_links_enabled")
  abuseThreshold        Int      @default(80) @map("abuse_threshold")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("global_settings")
}

model BlacklistedDomain {
  id        String   @id @default(uuid()) @db.Uuid
  hostname  String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacklisted_domains")
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid @map("actor_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation("ActorAuditEvents", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([resource, resourceId])
  @@map("audit_events")
}
